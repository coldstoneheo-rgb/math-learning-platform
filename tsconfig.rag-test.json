{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "noEmit": false,
    "noEmitOnError": true,
    "outDir": ".tmp/rag-test",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "src/lib/rag-diagnostics.ts",
    "src/types/**/*.ts",
    "tests/rag-diagnostics.test.mts"
  ]
}
